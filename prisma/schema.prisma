generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  superadmin
  admin
  user
}

model Company {
  id                 String          @id @default(auto()) @map("_id") @db.ObjectId
  companyName        String
  logo               String?
  subscriptionType   String          @default("Basic")
  subscriptionExpiry DateTime
  // Hard cutoff used by middleware. Authoritative source of truth for whether
  // a tenant's logins still work. Updated when superadmin records a payment.
  subscriptionUntil  DateTime?
  // Tier that drives feature entitlements via PLAN_FEATURES in lib/plans.ts.
  // Resolution order at runtime: subscription-active → plan-default → featureFlags override.
  plan               String          @default("standard")
  // Per-company feature overrides on top of plan defaults. Shape:
  //   { "feature.daily_plan": true,  // grant beyond plan
  //     "feature.export_leads": false // revoke despite plan
  //   }
  // Resolved by lib/entitlements.ts hasFeature().
  featureFlags       Json?
  status             String          @default("active")
  // Max number of `role:user` team members the broker admin may create.
  // Enforced at /api/users POST.
  seatLimit          Int             @default(5)
  // What the superadmin (you) charges this customer per cycle.
  monthlyFee         Float?
  // Free-text notes the superadmin keeps about this customer (contract terms,
  // contact preferences, etc.). Never shown to the broker.
  notes              String?
  // Superadmin user id who onboarded this company. Audit trail.
  onboardedBy        String?         @db.ObjectId
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  users              User[]
  clients            Client[]
  commissions        Commission[]
  commissionPayments CommissionPayment[]
  dealPayments       DealPayment[]
  commissionSplits   CommissionSplit[]
  splitPayouts       CommissionSplitPayout[]
  otps               OTP[]
  invoices           Invoice[]
  monthlyBudgets     MonthlyBudget[]
  properties         Property[]
  paymentRecords     PaymentRecord[]
  @@index([status])
  @@index([subscriptionExpiry])
  @@index([subscriptionUntil])
  @@index([status, subscriptionUntil])
}

model User {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  phone        String       @unique
  email        String       @unique
  password     String
  role         Role         @default(user)
  companyId    String?      @db.ObjectId
  profilePhoto String?
  status       String       @default("active")
  // null  = never verified (e.g. new signup awaiting email-link click)
  // Date  = verified at this timestamp
  emailVerified     DateTime?
  // Bumping this invalidates all previously-issued tokens for this user.
  // Set at login-issue-time (as `tv` JWT claim) so revocation is instant.
  tokenVersion Int          @default(0)
  // F24 — per-user permission overrides on top of the role default.
  // Shape: { "clients.read": true, "commissions.delete": false, ... }
  // Resolution: role baseline -> per-user grant (true) -> per-user revoke (false).
  // Gated by feature.granular_permissions (Enterprise).
  permissions  Json?
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clients      Client[]
  commissions  Commission[]
  properties   Property[]   @relation("PropertyCreator")
  verificationTokens      VerificationToken[]
  trustedDevices          TrustedDevice[]
  sessions                UserSession[]
  commissionPaymentsMade  CommissionPayment[] @relation("CommissionPaymentRecorder")
  dealPaymentsRecorded    DealPayment[]       @relation("DealPaymentRecorder")
  splitsParticipating     CommissionSplit[]   @relation("SplitParticipant")
  splitPayoutsRecorded    CommissionSplitPayout[] @relation("SplitPayoutRecorder")
  @@index([role])
  @@index([companyId, role, status])
  @@index([deletedAt])
  @@index([emailVerified])
}

model UserSession {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  companyId  String    @db.ObjectId
  loginAt    DateTime  @default(now())
  logoutAt   DateTime?
  duration   Int?
  ipAddress  String?
  userAgent  String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, loginAt])
  @@index([companyId, loginAt])
  @@map("user_sessions")
}

// One-time signed tokens used for email verification + (future) password reset links.
// The link we email contains the raw token; only the hash is stored.
model VerificationToken {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  tokenHash  String    @unique
  purpose    String    // 'email-verification' | (future) 'password-reset'
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// Tracks devices a user has completed an OTP challenge on. While a device's
// row is active (not expired, not revoked), subsequent logins from that device
// skip the OTP step — email+password is enough. Admins never use these rows
// (the login code always forces OTP for admin + superadmin).
model TrustedDevice {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  tokenHash   String    @unique   // sha256 of the cookie value
  label       String?              // "Chrome on macOS" — populated from UA for future UI
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  lastUsedAt  DateTime  @default(now())
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([expiresAt])
  @@map("trusted_devices")
}

model Client {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  clientName        String
  phone             String
  email             String?
  companyName       String?
  requirementType   String
  inquiryType       String
  budget            Float?
  preferredLocation String?
  address           String?
  visitingDate      DateTime?
  visitingTime      String?
  propertyVisited   Boolean      @default(false)
  visitStatus       String       @default("NotVisited")
  followUpDate      DateTime?
  nextFollowUp      DateTime?
  lastContactDate   DateTime?
  status            String       @default("New")
  source            String?
  notes             String?
  companyId         String       @db.ObjectId
  createdBy         String       @db.ObjectId
  // Current owner of the lead. Defaults to createdBy on insert; flipped by
  // the transfer endpoint when a teammate hands the lead over. Used by
  // list endpoints when filtering "leads owned by user X" — `createdBy`
  // stays put as an audit trail of who first captured the lead.
  ownedBy           String?      @db.ObjectId
  // Audit trail of the LAST transfer (older transfers live in AuditLog).
  // Null = lead has never been transferred.
  transferredFrom   String?      @db.ObjectId
  transferredAt     DateTime?
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  company           Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator           User         @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  commissions       Commission[]
  @@index([followUpDate])
  @@index([phone])
  @@index([deletedAt])
  // Hot paths: dashboard listing, team-scoped filters, date-range reports.
  // Leftmost-prefix rules cover single-field companyId / status queries too.
  @@index([companyId, createdBy, status, createdAt])
  @@index([companyId, ownedBy, status, createdAt])
  @@index([companyId, status, createdAt])
  @@index([companyId, visitingDate])
  // Soft-delete-aware composite — every list query filters deletedAt: null
  @@index([companyId, deletedAt, createdAt])
}

model Commission {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  clientId             String    @db.ObjectId
  companyId            String    @db.ObjectId
  salesPersonName      String?
  userId               String?   @db.ObjectId
  // The developer / builder counterparty on this deal. Free-text for now —
  // not a separate Builder master collection. Used for "deals by builder"
  // reports and shown alongside the client name in the manage-deal modal.
  builderName          String?
  dealAmount           Float
  // Denormalized running total of all non-deleted DealPayment.amount rows
  // (i.e. instalments the BUYER has paid the BUILDER). Kept in sync by the
  // deal-payments routes — same pattern as paidAmount/CommissionPayment.
  dealAmountPaid       Float     @default(0)
  // Derived from dealAmountPaid vs dealAmount:
  //   dealAmountPaid <= 0                     → "Open"
  //   0 < dealAmountPaid < dealAmount         → "InProgress"
  //   dealAmountPaid >= dealAmount            → "Completed"
  dealStatus           String    @default("Open")
  commissionPercentage Float
  commissionAmount     Float
  // Denormalized running total of all non-deleted CommissionPayment.amount
  // rows for this commission. Kept in sync by the /payments endpoints so
  // list views and totals don't have to aggregate on every read.
  paidAmount           Float     @default(0)
  // Derived from paidAmount vs commissionAmount:
  //   paidAmount <= 0                  → "Pending"
  //   0 < paidAmount < commissionAmount → "Partial"
  //   paidAmount >= commissionAmount   → "Paid"
  paidStatus           String    @default("Pending")
  // Populated only when paidStatus flips to "Paid" (final payment recorded).
  paymentDate          DateTime?
  paymentReference     String?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  client               Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user                 User?               @relation(fields: [userId], references: [id], onDelete: Restrict)
  company              Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments             CommissionPayment[]
  dealPayments         DealPayment[]
  splits               CommissionSplit[]
  splitPayouts         CommissionSplitPayout[]
  @@index([companyId])
  @@index([userId])
  @@index([clientId])
  @@index([paidStatus])
  @@index([deletedAt])
  // Hot paths: company totals, month-scoped payouts, status grouping
  @@index([companyId, paidStatus, createdAt])
  @@index([companyId, createdAt])
  @@index([companyId, deletedAt, createdAt])
}

// Ledger of individual payments recorded against a Commission. A commission
// starts with zero payments ("Pending"); each row here increments the parent
// Commission.paidAmount. When paidAmount >= commissionAmount the parent flips
// to "Paid"; anything in between is "Partial". Deleting a payment (soft)
// reverses its effect on paidAmount.
model CommissionPayment {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  commissionId   String     @db.ObjectId
  companyId      String     @db.ObjectId
  amount         Float
  paidOn         DateTime
  method         String?    // cash | upi | bank_transfer | cheque | other
  reference      String?    // txn id, cheque no, UPI ref
  notes          String?
  recordedBy     String     @db.ObjectId
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  commission     Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  company        Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recorder       User       @relation("CommissionPaymentRecorder", fields: [recordedBy], references: [id], onDelete: Restrict)
  @@index([commissionId, deletedAt])
  @@index([companyId, paidOn])
  @@index([recordedBy])
  @@map("commission_payments")
}

// Ledger of buyer→builder instalments on the underlying property deal.
// Distinct from CommissionPayment (which is builder→brokerage). Each row
// here is one stage of the buyer's payment to the developer (token,
// agreement, registry, loan disbursement, possession, etc.) and increments
// Commission.dealAmountPaid. Used so brokers can answer "how much of the
// ₹50L deal has actually flowed to the builder so far?" alongside the
// commission collection state.
model DealPayment {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  commissionId   String     @db.ObjectId
  companyId      String     @db.ObjectId
  amount         Float
  paidOn         DateTime
  // Stage of the deal the payment is associated with. Free-text would be
  // tempting but a fixed enum keeps the by-stage report sane.
  // Token | Agreement | Registry | LoanDisbursed | Possession | Other
  stage          String
  method         String?    // cash | upi | bank_transfer | cheque | other
  reference      String?    // txn id, cheque no, UPI ref
  notes          String?
  recordedBy     String     @db.ObjectId
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  commission     Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  company        Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recorder       User       @relation("DealPaymentRecorder", fields: [recordedBy], references: [id], onDelete: Restrict)
  @@index([commissionId, deletedAt])
  @@index([companyId, paidOn])
  @@index([recordedBy])
  @@map("deal_payments")
}

// One slice of a commission's payout pie. Solo brokers have a single
// 100%-share split pointing to themselves. Brokerages with sub-brokers (or
// co-broking deals) have several splits whose `sharePercent` should sum to
// 100 — the API surfaces a soft warning if not, but never blocks the save
// because a deal can close before the final share is settled.
//
// `participantUserId` is null when the participant is an external co-broker
// or an ex-employee — `participantName` is denormalized so the historical
// row stays readable even if the user is later soft-deleted.
//
// `shareAmount` is auto-derived (commissionAmount × sharePercent / 100)
// every time either the parent's commissionAmount or this row's
// sharePercent changes. `paidOut` and `status` come from the
// CommissionSplitPayout ledger below.
model CommissionSplit {
  id                 String                   @id @default(auto()) @map("_id") @db.ObjectId
  commissionId       String                   @db.ObjectId
  companyId          String                   @db.ObjectId
  participantUserId  String?                  @db.ObjectId
  participantName    String
  sharePercent       Float
  shareAmount        Float                    @default(0)
  paidOut            Float                    @default(0)
  status             String                   @default("Pending") // Pending | Partial | Paid
  deletedAt          DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  commission         Commission               @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  company            Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  participant        User?                    @relation("SplitParticipant", fields: [participantUserId], references: [id], onDelete: SetNull)
  payouts            CommissionSplitPayout[]
  @@index([commissionId, deletedAt])
  @@index([companyId, participantUserId])
  @@index([companyId, deletedAt])
  @@map("commission_splits")
}

// Ledger of brokerage→participant payouts against a single CommissionSplit.
// Each row increments split.paidOut. When paidOut >= shareAmount the split
// flips to "Paid"; partial payments leave it "Partial". Soft-delete a row
// to reverse — totals recompute.
model CommissionSplitPayout {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  splitId      String           @db.ObjectId
  commissionId String           @db.ObjectId
  companyId    String           @db.ObjectId
  amount       Float
  paidOn       DateTime
  method       String?    // cash | upi | bank_transfer | cheque | other
  reference    String?
  notes        String?
  recordedBy   String           @db.ObjectId
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  split        CommissionSplit  @relation(fields: [splitId], references: [id], onDelete: Cascade)
  commission   Commission       @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recorder     User             @relation("SplitPayoutRecorder", fields: [recordedBy], references: [id], onDelete: Restrict)
  @@index([splitId, deletedAt])
  @@index([commissionId, deletedAt])
  @@index([companyId, paidOn])
  @@map("commission_split_payouts")
}

model OTP {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  phone      String
  companyId  String   @db.ObjectId
  otpHash    String
  attempts   Int      @default(0)
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@index([phone, companyId])
  @@index([expiresAt])
}

model EmailOTP {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  otpHash   String
  purpose   String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([email])
  @@index([email, purpose])
  @@index([expiresAt])
  @@map("email_otps")
}

model Invoice {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId         String   @db.ObjectId
  invoiceNumber     String   @unique
  amount            Float
  paymentStatus     String   @default("pending")
  planType          String
  razorpayOrderId   String?
  razorpayPaymentId String?
  validFrom         DateTime
  validUpto         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@index([companyId])
  @@index([paymentStatus])
  @@index([companyId, paymentStatus, createdAt])
}

model Property {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  propertyName   String
  address        String
  propertyType   String
  bhkType        String?
  vacateDate     DateTime?
  askingRent     Float?
  sellingPrice   Float?
  area           String?
  description    String?
  status         String   @default("Available")

  // F10 — structured project identity. All optional so existing rows
  // remain valid. Indexed by projectName for project-grouped reports.
  projectName    String?
  sectorNo       String?
  unitNo         String?
  towerNo        String?
  typology       String?

  // F11 — India-specific deal fields used during seller capture.
  // demand    : owner's asked price (negotiation starting point — usually
  //             higher than the broker's listed sellingPrice / askingRent).
  // paymentStatus: 'Pending' | 'Partial' | 'Completed' — buyer-side payment.
  // caseType  : 'Registry' (fresh registration) | 'Transfer' (resale via
  //             society NOC) | 'NewLaunch' (under-construction direct).
  // loanStatus: 'NotApplied' | 'Applied' | 'Sanctioned' | 'Disbursed'.
  demand         Float?
  paymentStatus  String?
  caseType       String?
  loanStatus     String?

  // Owner details
  ownerName      String
  // F12 — kept alongside ownerPhones for backward compatibility with code
  // paths that still read a single value (search, exports, legacy reports).
  // New writes always set both: ownerPhone = ownerPhones[0]. After all
  // call-sites migrate to ownerPhones, this field can be dropped.
  ownerPhone     String
  ownerPhones    String[]   @default([])
  ownerEmail     String?

  companyId      String   @db.ObjectId
  createdBy      String   @db.ObjectId
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator        User     @relation("PropertyCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([ownerPhone])
  @@index([deletedAt])
  @@index([companyId, status, createdAt])
  @@index([companyId, createdBy, status, createdAt])
  @@index([companyId, deletedAt, createdAt])
  // Project-grouped reports + Find Opportunity matcher (F19) will scan
  // by projectName + sectorNo, so this index covers both.
  @@index([companyId, projectName])
  @@index([companyId, sectorNo])
}

model MonthlyBudget {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId     String   @db.ObjectId
  month         String
  targetAmount  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@unique([companyId, month])
  @@index([companyId])
  @@map("monthly_budgets")
}

// Manual ledger of payments the superadmin (you) received from each broker
// company. Editing rows here is the only mechanism that extends a company's
// `subscriptionUntil` — keeps revenue tracking and access control in one place.
model PaymentRecord {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId   String   @db.ObjectId
  amount      Float
  paidOn      DateTime
  // Subscription window this payment buys. When recorded, Company.subscriptionUntil
  // is updated to MAX(current, coversUntil) so multiple payments stack cleanly.
  coversFrom  DateTime
  coversUntil DateTime
  method      String   // 'bank_transfer' | 'razorpay_link' | 'cash' | 'cheque' | 'upi'
  reference   String?  // bank txn id, cheque no, UPI ref, etc.
  notes       String?
  recordedBy  String   @db.ObjectId   // superadmin user id who logged it
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@index([companyId, paidOn])
  @@index([recordedBy])
  @@map("payment_records")
}

model Notification {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  companyId  String   @db.ObjectId
  type       String   // 'OVERDUE' | 'DUE_TODAY' | 'VISIT_TODAY' | 'NEW_ASSIGNMENT'
  clientId   String?  @db.ObjectId
  title      String
  message    String
  severity   String   // 'red' | 'yellow' | 'green'
  isRead     Boolean  @default(false)
  dateKey    String   // 'YYYY-MM-DD' for idempotency
  createdAt  DateTime @default(now())
  @@unique([userId, clientId, type, dateKey])
  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model EmailLog {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  recipientUserId String   @db.ObjectId
  recipientEmail  String
  emailType       String   // 'weekly_report'
  status          String   // 'sent' | 'failed'
  error           String?
  sentAt          DateTime @default(now())
  @@index([recipientUserId, sentAt])
  @@index([emailType, sentAt])
  @@map("email_logs")
}

// Marketing-site onboarding enquiries. Populated by the public
// /api/onboarding-enquiry endpoint (no auth). Replaces the old client-side
// mailto: flow which silently dropped leads whenever the user had no mail
// client configured. We persist to the DB AND fire an email — either
// channel alone was unreliable.
model OnboardingEnquiry {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  company    String
  email      String
  phone      String?
  city       String?
  teamSize   String?  // '1' | '2-5' | '6-15' | '16+'
  plan       String?  // 'Solo' | 'Team' | 'Enterprise'
  message    String?
  source     String?  @default("landing") // 'landing' | 'ads' | ...
  ipAddress  String?
  userAgent  String?
  handled    Boolean  @default(false)
  handledBy  String?  @db.ObjectId  // superadmin user id who responded
  handledAt  DateTime?
  notes      String?  // internal notes from whoever replied
  createdAt  DateTime @default(now())
  @@index([handled, createdAt])
  @@index([email])
  @@index([createdAt])
  @@map("onboarding_enquiries")
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId  String   @db.ObjectId
  userId     String   @db.ObjectId
  action     String   // e.g. "client.create", "commission.delete"
  resource   String   // e.g. "Client", "Commission"
  resourceId String?  @db.ObjectId
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// F20 — Learn & Grow resource library. Folders contain files. Files are
// URL-based for now (Vercel Blob / S3 wiring is a follow-up). Each row
// is per-company; admins typically curate a shared set, team members
// browse and open links.
model LearnFolder {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId String   @db.ObjectId
  name      String
  createdBy String   @db.ObjectId
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  files     LearnFile[]
  @@index([companyId, deletedAt])
  @@map("learn_folders")
}

model LearnFile {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  folderId  String   @db.ObjectId
  name      String
  url       String
  // 'pdf' | 'video' | 'image' | 'doc' | 'link' — UI hint for icon choice.
  kind      String   @default("link")
  notes     String?
  createdBy String   @db.ObjectId
  deletedAt DateTime?
  createdAt DateTime @default(now())
  folder    LearnFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  @@index([folderId, deletedAt])
  @@map("learn_files")
}

// Public landing-page feedback. Anyone can submit; only approved rows
// surface as testimonials on the landing page. Approvals happen in the
// superadmin console. Spam protection is rate-limited at the API layer.
model Feedback {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  role        String?
  rating      Int       @default(5)
  message     String
  email       String?
  source      String?
  // 'pending' | 'approved' | 'rejected'. Rejected stays in the table for
  // audit + spam analysis; only 'approved' rows are public.
  status      String    @default("pending")
  approvedAt  DateTime?
  approvedBy  String?   @db.ObjectId
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([status, createdAt])
  @@index([status, rating])
  @@map("feedback")
}

// F21 — public reference catalogue of projects (with brochure PDFs).
// Distinct from F17 Project (which is a real working asset on this
// company's books). Use for "shareable info" the team distributes
// externally — a curated list a salesperson can browse and copy a
// brochure link from.
model ReferenceProject {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId          String   @db.ObjectId
  projectName        String
  location           String?
  typology           String?
  sector             String?
  // Free-text price string so brokers can write "₹2.4Cr" or "₹25k/sqft"
  // without wedging us on units. UI shows verbatim.
  price              String?
  size               String?
  propertyType       String?
  constructionStatus String?
  pdfUrl             String?
  remarks            String?
  createdBy          String   @db.ObjectId
  deletedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@index([companyId, propertyType])
  @@index([companyId, deletedAt, createdAt])
  @@map("reference_projects")
}

// F17 — Projects Working hierarchy. Project → Tower → Unit. Each level
// is a separate document with parent foreign keys. We keep cascades on
// Tower → Project deletes only — Unit-level data is the most valuable
// audit trail and we'd rather soft-delete with deletedAt than wipe.
model Project {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId          String   @db.ObjectId
  name               String
  // 'Commercial' | 'Residential'
  propertyType       String
  // 'ReadyToMove' | 'UnderConstruction'
  constructionStatus String
  city               String?
  location           String?
  sector             String?
  createdBy          String   @db.ObjectId
  deletedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  towers             Tower[]
  @@index([companyId, propertyType, constructionStatus])
  @@index([companyId, deletedAt, createdAt])
  @@map("projects")
}

model Tower {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId String   @db.ObjectId
  name      String
  units     Unit[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  @@index([projectId])
  @@map("towers")
}

model Unit {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  towerId     String   @db.ObjectId
  floor       Int
  unitNo      String
  ownerName   String?
  ownerEmail  String?
  ownerPhones String[] @default([])
  typology    String?
  size        String?
  // 'Vacant' | 'SelfOccupied' | 'Rented' | 'ForSale' | 'Sold'
  status      String   @default("Vacant")
  remarks     String?
  assignedTo  String?  @db.ObjectId
  tower       Tower    @relation(fields: [towerId], references: [id], onDelete: Cascade)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([towerId])
  @@index([status])
  @@map("units")
}

// F18 — incoming requirements from outside brokers / channel partners.
// Distinct from Client (a buyer/seller lead) and from User (an internal
// teammate). Brokers reach out asking "I have a 3BHK buyer in Sector 24 —
// got anything?" and we record that demand here so the team can match it
// against inventory or hand the broker over to the right salesperson.
model BrokerRequirement {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId     String   @db.ObjectId
  brokerName    String
  brokerCompany String?
  contact       String   // primary phone — kept loose-typed; brokers paste anything
  email         String?
  // 'Hot' | 'Ok' | 'Visit' — see BROKER_REQ_STATUSES in lib/constants.ts.
  status        String   @default("Ok")
  requirement   String   // free-text description of what they're looking for
  source        String?
  followUpDate  DateTime?
  remark        String?
  createdBy     String   @db.ObjectId
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([companyId, status, createdAt])
  @@index([companyId, deletedAt, createdAt])
  @@index([companyId, createdBy])
  @@map("broker_requirements")
}

// One row per (user, dateKey) capturing morning commitment + evening achievements.
// dateKey is "YYYY-MM-DD" in the company's timezone, used for idempotent upsert.
// morning/evening are JSON blobs so we can evolve the form fields without migrations.
model DailyPlan {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  companyId  String   @db.ObjectId
  dateKey    String   // 'YYYY-MM-DD'
  date       DateTime // start-of-day for sorting/range queries
  morning    Json?    // { onlinePortal, whatsappPost, emailsWorking, buyersWorking, sellersWorking, meetingsVisits, note }
  evening    Json?    // same shape
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@unique([userId, dateKey])
  @@index([companyId, date])
  @@index([userId, date])
  @@map("daily_plans")
}

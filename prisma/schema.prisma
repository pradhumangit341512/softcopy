generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  superadmin
  admin
  user
}

model Company {
  id                 String          @id @default(auto()) @map("_id") @db.ObjectId
  companyName        String
  logo               String?
  subscriptionType   String          @default("Basic")
  subscriptionExpiry DateTime
  status             String          @default("active")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  users              User[]
  clients            Client[]
  commissions        Commission[]
  otps               OTP[]
  invoices           Invoice[]
  monthlyBudgets     MonthlyBudget[]
  properties         Property[]
  @@index([status])
  @@index([subscriptionExpiry])
}

model User {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  phone        String       @unique
  email        String       @unique
  password     String
  role         Role         @default(user)
  companyId    String?      @db.ObjectId
  profilePhoto String?
  status       String       @default("active")
  // Bumping this invalidates all previously-issued tokens for this user.
  // Set at login-issue-time (as `tv` JWT claim) so revocation is instant.
  tokenVersion Int          @default(0)
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clients      Client[]
  commissions  Commission[]
  properties   Property[]   @relation("PropertyCreator")
  @@index([role])
  @@index([companyId, role, status])
  @@index([deletedAt])
}

model Client {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  clientName        String
  phone             String
  email             String?
  companyName       String?
  requirementType   String
  inquiryType       String
  budget            Float?
  preferredLocation String?
  address           String?
  visitingDate      DateTime?
  visitingTime      String?
  propertyVisited   Boolean      @default(false)
  visitStatus       String       @default("NotVisited")
  followUpDate      DateTime?
  nextFollowUp      DateTime?
  lastContactDate   DateTime?
  status            String       @default("New")
  source            String?
  notes             String?
  companyId         String       @db.ObjectId
  createdBy         String       @db.ObjectId
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  company           Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator           User         @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  commissions       Commission[]
  @@index([followUpDate])
  @@index([phone])
  @@index([deletedAt])
  // Hot paths: dashboard listing, team-scoped filters, date-range reports.
  // Leftmost-prefix rules cover single-field companyId / status queries too.
  @@index([companyId, createdBy, status, createdAt])
  @@index([companyId, status, createdAt])
  @@index([companyId, visitingDate])
}

model Commission {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  clientId             String    @db.ObjectId
  companyId            String    @db.ObjectId
  salesPersonName      String?
  userId               String?   @db.ObjectId
  dealAmount           Float
  commissionPercentage Float
  commissionAmount     Float
  paidStatus           String    @default("Pending")
  paymentDate          DateTime?
  paymentReference     String?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  client               Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user                 User?     @relation(fields: [userId], references: [id], onDelete: Restrict)
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@index([companyId])
  @@index([userId])
  @@index([clientId])
  @@index([paidStatus])
  @@index([deletedAt])
  // Hot paths: company totals, month-scoped payouts, status grouping
  @@index([companyId, paidStatus, createdAt])
  @@index([companyId, createdAt])
}

model OTP {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  phone      String
  companyId  String   @db.ObjectId
  otpHash    String
  attempts   Int      @default(0)
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@index([phone, companyId])
  @@index([expiresAt])
}

model EmailOTP {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  otpHash   String
  purpose   String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([email])
  @@index([email, purpose])
  @@index([expiresAt])
  @@map("email_otps")
}

model Invoice {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId         String   @db.ObjectId
  invoiceNumber     String   @unique
  amount            Float
  paymentStatus     String   @default("pending")
  planType          String
  razorpayOrderId   String?
  razorpayPaymentId String?
  validFrom         DateTime
  validUpto         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@index([companyId])
  @@index([paymentStatus])
  @@index([companyId, paymentStatus, createdAt])
}

model Property {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  propertyName   String
  address        String
  propertyType   String
  bhkType        String?
  vacateDate     DateTime?
  askingRent     Float?
  sellingPrice   Float?
  area           String?
  description    String?
  status         String   @default("Available")

  // Owner details
  ownerName      String
  ownerPhone     String
  ownerEmail     String?

  companyId      String   @db.ObjectId
  createdBy      String   @db.ObjectId
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator        User     @relation("PropertyCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([ownerPhone])
  @@index([deletedAt])
  @@index([companyId, status, createdAt])
  @@index([companyId, createdBy, status, createdAt])
}

model MonthlyBudget {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId     String   @db.ObjectId
  month         String
  targetAmount  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@unique([companyId, month])
  @@index([companyId])
  @@map("monthly_budgets")
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId  String   @db.ObjectId
  userId     String   @db.ObjectId
  action     String   // e.g. "client.create", "commission.delete"
  resource   String   // e.g. "Client", "Commission"
  resourceId String?  @db.ObjectId
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}
